#!/usr/bin/env bash
# Reclaim disk space by clearing safely-prunable caches and VM state.
#
# Default run (safe — everything regenerates on next use):
#   - Docker build cache
#   - Claude Desktop sandbox VM (rootfs.img)
#   - Claude Desktop Electron cache (Cache, Code Cache, GPUCache)
#   - Claude Desktop ShipIt old installer cache
#   - BambuStudio logs
#   - Go module cache + build cache
#   - Go tool caches (goimports, golangci-lint)
#   - uv (Python) cache
#   - pip cache
#   - npm cache
#   - node-gyp cache
#   - Bun install cache (~/.bun/install/cache)
#   - Spotify cache
#   - Homebrew old versions + downloads
#   - Gradle caches
#   - Dart/Flutter pub-cache
#   - Dart Analyzer server cache (~/.dartServer)
#   - Discord cache
#   - Raycast old update installers
#   - Google Updater crx_cache (~/Library/.../GoogleUpdater/crx_cache)
#   - Autodesk Fusion 360 webdeploy installer cache
#     (~/Library/.../Autodesk/webdeploy/production) — re-downloaded by the
#     Fusion 360 installer/launcher.
#   - Chrome on-device ML models + component caches (OptGuide*, WasmTtsEngine,
#     component_crx_cache, GraphiteDawnCache, etc.) — Chrome re-downloads or
#     rebuilds these on demand. User profile data (Default/*) is left alone.
#   - VSCode-electron IDE caches (Windsurf, Antigravity): Cache, CachedData,
#     Code Cache, logs — only when the IDE is not running.
#
# With --playwright:
#   - Also delete Playwright browser downloads (~/Library/Caches/ms-playwright).
#     Off by default because playwright-mcp servers commonly hold them open.
#
# With --node-modules:
#   - Also delete node_modules dirs under ~/Work whose project
#     hasn't been touched in 90+ days (by package.json mtime).
#
# With --build-artifacts:
#   - Also delete .venv/build/target/dist/.next/.turbo dirs under ~/Work
#     whose project marker file is untouched >90d.
#
# With --ios-simulators:
#   - Also delete all installed iOS/watchOS/tvOS/visionOS Simulator
#     runtimes (19GB+) and unavailable simulator devices. Re-downloadable
#     via Xcode → Settings → Platforms.
#
# Skips any target whose owning app is currently running.

set -u

RED=$'\e[31m'; GRN=$'\e[32m'; YLW=$'\e[33m'; BLU=$'\e[34m'; DIM=$'\e[2m'; RST=$'\e[0m'

info()  { printf '%s[·]%s %s\n' "$BLU" "$RST" "$*"; }
ok()    { printf '%s[✓]%s %s\n' "$GRN" "$RST" "$*"; }
warn()  { printf '%s[!]%s %s\n' "$YLW" "$RST" "$*"; }
skip()  { printf '%s[-]%s %s\n' "$DIM" "$RST" "$*"; }

CLEAN_NODE_MODULES=0
CLEAN_BUILD_ARTIFACTS=0
CLEAN_IOS_SIMULATORS=0
CLEAN_PLAYWRIGHT=0
for arg in "$@"; do
  case "$arg" in
    --node-modules)    CLEAN_NODE_MODULES=1 ;;
    --build-artifacts) CLEAN_BUILD_ARTIFACTS=1 ;;
    --ios-simulators)  CLEAN_IOS_SIMULATORS=1 ;;
    --playwright)      CLEAN_PLAYWRIGHT=1 ;;
    --all)             CLEAN_NODE_MODULES=1; CLEAN_BUILD_ARTIFACTS=1
                       CLEAN_IOS_SIMULATORS=1; CLEAN_PLAYWRIGHT=1 ;;
    -h|--help)
      sed -n '/^# Reclaim/,/^$/p' "$0" | sed 's/^# \{0,1\}//'
      exit 0 ;;
    *) echo "unknown arg: $arg" >&2; exit 2 ;;
  esac
done

data_used_gib() {
  df -g /System/Volumes/Data 2>/dev/null | awk 'NR==2 {print $3}'
}

human_size() {
  [[ -e "$1" ]] || { echo "-"; return; }
  du -sh "$1" 2>/dev/null | awk '{print $1}'
}

app_running() { pgrep -qf "$1"; }

clean_docker() {
  info "Docker build cache"
  if ! command -v docker >/dev/null 2>&1; then skip "docker not installed"; return; fi
  if ! docker info >/dev/null 2>&1; then
    skip "Docker daemon not running — start Docker Desktop to prune"
    return
  fi
  docker builder prune -af >/dev/null 2>&1 && ok "Docker build cache pruned" \
    || warn "docker builder prune failed"
}

clean_claude_vm() {
  local img="$HOME/Library/Application Support/Claude/vm_bundles/claudevm.bundle/rootfs.img"
  info "Claude Desktop sandbox VM"
  if [[ ! -f "$img" ]]; then skip "rootfs.img not present"; return; fi
  if app_running "Claude.app/Contents/MacOS/Claude"; then
    warn "Claude Desktop is running — quit it and re-run to reclaim"
    return
  fi
  local size; size=$(human_size "$img")
  rm -f "$img" && ok "Deleted rootfs.img ($size) — VM will rebuild on next launch"
}

clean_claude_electron() {
  local base="$HOME/Library/Application Support/Claude"
  info "Claude Desktop Electron cache"
  [[ -d "$base" ]] || { skip "not present"; return; }
  if app_running "Claude.app/Contents/MacOS/Claude"; then
    warn "Claude Desktop is running — quit it and re-run to reclaim"
    return
  fi
  local total_k=0 d kb
  for d in Cache "Code Cache" GPUCache DawnWebGPUCache DawnGraphiteCache; do
    [[ -d "$base/$d" ]] || continue
    kb=$(du -sk "$base/$d" 2>/dev/null | awk '{print $1}')
    rm -rf "$base/$d" && total_k=$((total_k + kb))
  done
  if (( total_k > 0 )); then
    ok "Claude Electron caches cleared (~$((total_k / 1024))M)"
  else
    skip "nothing to clean"
  fi
}

clean_claude_shipit() {
  local dir="$HOME/Library/Caches/com.anthropic.claudefordesktop.ShipIt"
  info "Claude Desktop ShipIt (old installer cache)"
  [[ -d "$dir" ]] || { skip "not present"; return; }
  # Only blow away the staged update bundles, keep ShipItState.plist + logs.
  local total_k=0 staged kb
  while IFS= read -r -d '' staged; do
    kb=$(du -sk "$staged" 2>/dev/null | awk '{print $1}')
    rm -rf "$staged" && total_k=$((total_k + kb))
  done < <(find "$dir" -mindepth 1 -maxdepth 1 -name 'update.*' -print0 2>/dev/null)
  if (( total_k > 0 )); then
    ok "ShipIt installer cache cleared (~$((total_k / 1024))M)"
  else
    skip "nothing staged"
  fi
}

clean_bambu_logs() {
  local dir="$HOME/Library/Application Support/BambuStudio/log"
  info "BambuStudio logs"
  if [[ ! -d "$dir" ]]; then skip "log dir not present"; return; fi
  if app_running "BambuStudio"; then
    warn "Bambu Studio is running — quit it and re-run to reclaim"
    return
  fi
  local size; size=$(human_size "$dir")
  if [[ "$size" == "-" || "$size" == "0B" ]]; then skip "nothing to clean"; return; fi
  find "$dir" -mindepth 1 -delete 2>/dev/null && ok "Cleared BambuStudio logs ($size)"
}

clean_go_caches() {
  info "Go caches (module + build)"
  if ! command -v go >/dev/null 2>&1; then skip "go not installed"; return; fi
  local mod build
  mod=$(human_size "$(go env GOMODCACHE 2>/dev/null)")
  build=$(human_size "$(go env GOCACHE 2>/dev/null)")
  # go clean -modcache requires chmod +w on read-only module files; it handles that itself.
  go clean -modcache 2>/dev/null && ok "Go module cache cleared (${mod})" \
    || warn "go clean -modcache failed"
  go clean -cache 2>/dev/null && ok "Go build cache cleared (${build})" \
    || warn "go clean -cache failed"
}

clean_go_tool_caches() {
  info "Go tool caches (goimports, golangci-lint)"
  local total_k=0 d kb
  for d in "$HOME/Library/Caches/goimports" "$HOME/Library/Caches/golangci-lint"; do
    [[ -d "$d" ]] || continue
    kb=$(du -sk "$d" 2>/dev/null | awk '{print $1}')
    rm -rf "$d" && total_k=$((total_k + kb))
  done
  if (( total_k > 0 )); then
    ok "Go tool caches cleared (~$((total_k / 1024))M)"
  else
    skip "nothing to clean"
  fi
}

clean_uv_cache() {
  info "uv (Python) cache"
  if ! command -v uv >/dev/null 2>&1; then skip "uv not installed"; return; fi
  local size; size=$(human_size "$HOME/.cache/uv")
  uv cache clean >/dev/null 2>&1 && ok "uv cache cleared (${size})" \
    || warn "uv cache clean failed"
}

clean_npm_cache() {
  info "npm cache"
  if ! command -v npm >/dev/null 2>&1; then skip "npm not installed"; return; fi
  local size; size=$(human_size "$HOME/.npm")
  npm cache clean --force >/dev/null 2>&1 && ok "npm cache cleared (${size})" \
    || warn "npm cache clean failed"
}

clean_pip_cache() {
  info "pip cache"
  local dir="$HOME/Library/Caches/pip"
  [[ -d "$dir" ]] || { skip "not present"; return; }
  local size; size=$(human_size "$dir")
  if command -v pip3 >/dev/null 2>&1; then
    pip3 cache purge >/dev/null 2>&1 && ok "pip cache cleared (${size})" \
      || { rm -rf "$dir" && ok "pip cache cleared via rm (${size})"; }
  else
    rm -rf "$dir" && ok "pip cache cleared (${size})"
  fi
}

clean_node_gyp_cache() {
  local dir="$HOME/Library/Caches/node-gyp"
  info "node-gyp cache"
  [[ -d "$dir" ]] || { skip "not present"; return; }
  local size; size=$(human_size "$dir")
  rm -rf "$dir" && ok "node-gyp cache cleared (${size})"
}

clean_bun_cache() {
  local dir="$HOME/.bun/install/cache"
  info "Bun install cache"
  [[ -d "$dir" ]] || { skip "not present"; return; }
  local size; size=$(human_size "$dir")
  if command -v bun >/dev/null 2>&1; then
    bun pm cache rm >/dev/null 2>&1 && ok "Bun cache cleared (${size})" \
      || { rm -rf "$dir" && ok "Bun cache cleared via rm (${size})"; }
  else
    rm -rf "$dir" && ok "Bun cache cleared (${size})"
  fi
}

clean_homebrew() {
  info "Homebrew (old versions + downloads)"
  if ! command -v brew >/dev/null 2>&1; then skip "brew not installed"; return; fi
  local out
  out=$(brew cleanup --prune=all 2>&1)
  # brew prints a summary line like "This operation has freed approximately X of disk space."
  local freed
  freed=$(printf '%s\n' "$out" | awk -F'approximately ' '/freed approximately/ {print $2; exit}' | sed 's/ of.*//')
  if [[ -n "$freed" ]]; then
    ok "Homebrew cleaned (${freed} freed)"
  else
    ok "Homebrew cleaned (nothing to remove)"
  fi
}

clean_spotify_cache() {
  local dir="$HOME/Library/Caches/com.spotify.client"
  info "Spotify cache"
  if [[ ! -d "$dir" ]]; then skip "not present"; return; fi
  if app_running "Spotify"; then
    warn "Spotify is running — quit it and re-run to reclaim"
    return
  fi
  local size; size=$(human_size "$dir")
  find "$dir" -mindepth 1 -delete 2>/dev/null && ok "Spotify cache cleared (${size})"
}

clean_gradle() {
  local dir="$HOME/.gradle/caches"
  info "Gradle caches"
  [[ -d "$dir" ]] || { skip "not present"; return; }
  local size; size=$(human_size "$dir")
  rm -rf "$dir" && ok "Gradle caches cleared (${size})"
}

clean_pub_cache() {
  info "Dart/Flutter pub-cache"
  if command -v dart >/dev/null 2>&1; then
    local size; size=$(human_size "$HOME/.pub-cache")
    dart pub cache clean -f >/dev/null 2>&1 && ok "pub-cache cleared (${size})" \
      || warn "dart pub cache clean failed"
  else
    local dir="$HOME/.pub-cache"
    [[ -d "$dir" ]] || { skip "not present"; return; }
    local size; size=$(human_size "$dir")
    # Keep the directory (Flutter re-uses it); just clear hosted/git contents
    find "$dir" -mindepth 1 -delete 2>/dev/null && ok "pub-cache cleared (${size})"
  fi
}

clean_dart_server() {
  local dir="$HOME/.dartServer"
  info "Dart Analyzer server cache"
  [[ -d "$dir" ]] || { skip "not present"; return; }
  # Skip if dart analysis server is currently running.
  if pgrep -qf 'dart.*analysis_server'; then
    warn "dart analysis server is running — skipping"
    return
  fi
  local size; size=$(human_size "$dir")
  rm -rf "$dir" && ok "Dart Analyzer cache cleared (${size})"
}

clean_autodesk_webdeploy() {
  local dir="$HOME/Library/Application Support/Autodesk/webdeploy/production"
  info "Autodesk Fusion 360 webdeploy cache"
  [[ -d "$dir" ]] || { skip "not present"; return; }
  if pgrep -qf 'Autodesk Fusion 360\|Fusion360'; then
    warn "Fusion 360 is running — quit it and re-run to reclaim"
    return
  fi
  local size; size=$(human_size "$dir")
  rm -rf "$dir" && ok "Autodesk webdeploy cache cleared (${size}) — re-downloaded on next Fusion launch"
}

clean_chrome_models() {
  local base="$HOME/Library/Application Support/Google/Chrome"
  info "Chrome on-device ML models + component caches"
  [[ -d "$base" ]] || { skip "not present"; return; }
  if app_running "Google Chrome.app/Contents/MacOS/Google Chrome"; then
    warn "Chrome is running — quit it and re-run to reclaim"
    return
  fi
  # All Chrome-managed, regenerated on demand. Profile data under Default/ is
  # deliberately NOT touched (extensions, cookies, history, sync, etc.).
  local subs=(
    OptGuideOnDeviceModel
    OptGuideOnDeviceClassifierModel
    optimization_guide_model_store
    component_crx_cache
    extensions_crx_cache
    WasmTtsEngine
    OnDeviceHeadSuggestModel
    GraphiteDawnCache
    ShaderCache
    GrShaderCache
    GPUCache
    DawnWebGPUCache
    DawnGraphiteCache
  )
  local total_k=0 sub kb
  for sub in "${subs[@]}"; do
    [[ -d "$base/$sub" ]] || continue
    kb=$(du -sk "$base/$sub" 2>/dev/null | awk '{print $1}')
    rm -rf "$base/$sub" && total_k=$((total_k + kb))
  done
  if (( total_k > 0 )); then
    ok "Chrome model/cache dirs cleared (~$((total_k / 1024))M)"
  else
    skip "nothing to clean"
  fi
}

clean_google_updater() {
  local dir="$HOME/Library/Application Support/Google/GoogleUpdater/crx_cache"
  info "Google Updater installer cache"
  [[ -d "$dir" ]] || { skip "not present"; return; }
  local size; size=$(human_size "$dir")
  find "$dir" -mindepth 1 -delete 2>/dev/null && ok "Google Updater cache cleared (${size})"
}

clean_vscode_electron_caches() {
  info "VSCode-electron IDE caches (Windsurf, Antigravity)"
  local base ide cleaned=0 total_k=0 sub kb
  # name => process pattern
  local -a ides=(Windsurf Antigravity)
  local -a procs=("Windsurf.app/Contents/MacOS/Electron" "Antigravity.app/Contents/MacOS/Electron")
  local i
  for i in 0 1; do
    ide="${ides[$i]}"
    base="$HOME/Library/Application Support/$ide"
    [[ -d "$base" ]] || continue
    if app_running "${procs[$i]}" || app_running "$ide.app"; then
      printf '  %s-%s %s running — skipped\n' "$DIM" "$RST" "$ide"
      continue
    fi
    for sub in Cache CachedData "Code Cache" GPUCache logs Crashpad; do
      [[ -d "$base/$sub" ]] || continue
      kb=$(du -sk "$base/$sub" 2>/dev/null | awk '{print $1}')
      rm -rf "$base/$sub" && total_k=$((total_k + kb))
    done
    cleaned=1
    printf '  %s✓%s %s cleared\n' "$GRN" "$RST" "$ide"
  done
  if (( cleaned == 0 )); then
    skip "nothing cleaned"
  else
    ok "VSCode-electron caches cleared (~$((total_k / 1024))M)"
  fi
}

clean_playwright_browsers() {
  local dir="$HOME/Library/Caches/ms-playwright"
  info "Playwright browser downloads"
  [[ -d "$dir" ]] || { skip "not present"; return; }
  if pgrep -qf 'playwright-mcp\|playwright/mcp' || pgrep -qf '@playwright/test'; then
    warn "playwright process is running — skipping (kill MCP server and re-run)"
    return
  fi
  local size; size=$(human_size "$dir")
  rm -rf "$dir" && ok "Playwright browsers cleared (${size}) — re-download via 'npx playwright install'"
}

clean_discord() {
  local dir="$HOME/Library/Application Support/discord/Cache"
  info "Discord cache"
  [[ -d "$dir" ]] || { skip "not present"; return; }
  if app_running "Discord.app/Contents/MacOS/Discord"; then
    warn "Discord is running — quit to reclaim"
    return
  fi
  local size; size=$(human_size "$dir")
  find "$dir" -mindepth 1 -delete 2>/dev/null && ok "Discord cache cleared (${size})"
}

clean_raycast_updates() {
  local dir="$HOME/Library/Application Support/com.raycast.macos/Updates"
  info "Raycast old update installers"
  [[ -d "$dir" ]] || { skip "not present"; return; }
  local size; size=$(human_size "$dir")
  find "$dir" -mindepth 1 -delete 2>/dev/null && ok "Raycast updates cleared (${size})"
}

clean_stale_node_modules() {
  local root="$HOME/Work"
  local stale_days=90
  info "Stale node_modules under $root (package.json untouched >${stale_days}d)"
  [[ -d "$root" ]] || { skip "no $root"; return; }

  local total_k=0 count=0
  local cutoff
  cutoff=$(date -v-${stale_days}d +%s)

  # Iterate over every node_modules we can find under ~/Work.
  while IFS= read -r -d '' nm; do
    local project; project="$(dirname "$nm")"
    local pkg="$project/package.json"
    [[ -f "$pkg" ]] || continue
    local mtime; mtime=$(stat -f %m "$pkg" 2>/dev/null) || continue
    if (( mtime < cutoff )); then
      local kb; kb=$(du -sk "$nm" 2>/dev/null | awk '{print $1}')
      local size; size=$(human_size "$nm")
      rm -rf "$nm" && {
        printf '  %s✓%s %s (%s)\n' "$GRN" "$RST" "${project#$HOME/}" "$size"
        total_k=$((total_k + kb))
        count=$((count + 1))
      }
    fi
  done < <(find "$root" -type d -name node_modules -prune -print0 2>/dev/null)

  if (( count == 0 )); then
    skip "none stale"
  else
    local mb=$((total_k / 1024))
    ok "Removed $count stale node_modules dir(s), ~${mb}M total"
  fi
}

# Delete build/venv dirs under ~/Work for projects whose marker file
# (package.json, pyproject.toml, requirements.txt, Cargo.toml, CMakeLists.txt,
#  platformio.ini, pubspec.yaml, go.mod) is untouched >90d.
clean_stale_build_artifacts() {
  local root="$HOME/Work"
  local stale_days=90
  info "Stale build/venv dirs under $root (>${stale_days}d)"
  [[ -d "$root" ]] || { skip "no $root"; return; }

  local cutoff; cutoff=$(date -v-${stale_days}d +%s)
  local total_k=0 count=0

  # Dir names we consider artifacts (one per project, regenerable).
  local names=(.venv venv build target dist .next .turbo)
  local name_filter=()
  local n
  for n in "${names[@]}"; do
    name_filter+=(-o -name "$n")
  done
  # Strip the leading -o
  name_filter=("${name_filter[@]:1}")

  # Markers that indicate an active project.
  local markers=(package.json pyproject.toml requirements.txt setup.py \
                 Cargo.toml CMakeLists.txt platformio.ini pubspec.yaml go.mod)

  while IFS= read -r -d '' dir; do
    local project; project="$(dirname "$dir")"
    # Find newest marker mtime.
    local newest=0 m mtime
    for m in "${markers[@]}"; do
      [[ -f "$project/$m" ]] || continue
      mtime=$(stat -f %m "$project/$m" 2>/dev/null) || continue
      (( mtime > newest )) && newest=$mtime
    done
    (( newest == 0 )) && continue  # no marker — skip, unsafe to judge
    if (( newest < cutoff )); then
      local kb; kb=$(du -sk "$dir" 2>/dev/null | awk '{print $1}')
      local size; size=$(human_size "$dir")
      rm -rf "$dir" && {
        printf '  %s✓%s %s (%s)\n' "$GRN" "$RST" "${dir#$HOME/}" "$size"
        total_k=$((total_k + kb))
        count=$((count + 1))
      }
    fi
  done < <(find "$root" -type d \( "${name_filter[@]}" \) -prune -print0 2>/dev/null)

  if (( count == 0 )); then
    skip "none stale"
  else
    local mb=$((total_k / 1024))
    ok "Removed $count stale artifact dir(s), ~${mb}M total"
  fi
}

clean_ios_simulators() {
  info "iOS Simulator runtimes + unavailable devices"
  if ! command -v xcrun >/dev/null 2>&1; then
    skip "xcrun not installed"
    return
  fi
  if app_running "Simulator.app/Contents/MacOS/Simulator"; then
    warn "Simulator.app is running — quit it and re-run to reclaim"
    return
  fi

  local sim_dir="/Library/Developer/CoreSimulator"
  local before=""
  [[ -d "$sim_dir" ]] && before=$(human_size "$sim_dir")

  # Remove simulator devices whose runtime is missing (safe, they're dead refs).
  xcrun simctl delete unavailable >/dev/null 2>&1 || true

  # Parse installed runtime identifiers from `simctl runtime list`.
  local ids
  ids=$(xcrun simctl runtime list 2>/dev/null \
    | awk '{for(i=1;i<=NF;i++) if($i~/^com\.apple\.CoreSimulator\.SimRuntime\./) {print $i; next}}')

  if [[ -z "$ids" ]]; then
    skip "no simulator runtimes installed"
    return
  fi

  local count=0
  while IFS= read -r id; do
    [[ -z "$id" ]] && continue
    if xcrun simctl runtime delete "$id" >/dev/null 2>&1; then
      printf '  %s✓%s %s\n' "$GRN" "$RST" "$id"
      count=$((count + 1))
    fi
  done <<< "$ids"

  local after=""
  [[ -d "$sim_dir" ]] && after=$(human_size "$sim_dir")

  if (( count > 0 )); then
    ok "Removed $count simulator runtime(s) (${before:-?} -> ${after:-?})"
  else
    skip "nothing removed"
  fi
}

main() {
  local before after
  before=$(data_used_gib)
  printf '%sBefore:%s %sG used on Data volume\n\n' "$BLU" "$RST" "$before"

  clean_docker
  clean_claude_vm
  clean_claude_electron
  clean_claude_shipit
  clean_bambu_logs
  clean_go_caches
  clean_go_tool_caches
  clean_uv_cache
  clean_pip_cache
  clean_npm_cache
  clean_node_gyp_cache
  clean_bun_cache
  clean_spotify_cache
  clean_homebrew
  clean_gradle
  clean_pub_cache
  clean_dart_server
  clean_discord
  clean_raycast_updates
  clean_google_updater
  clean_chrome_models
  clean_autodesk_webdeploy
  clean_vscode_electron_caches
  (( CLEAN_PLAYWRIGHT ))      && clean_playwright_browsers
  (( CLEAN_NODE_MODULES ))    && clean_stale_node_modules
  (( CLEAN_BUILD_ARTIFACTS )) && clean_stale_build_artifacts
  (( CLEAN_IOS_SIMULATORS ))  && clean_ios_simulators

  after=$(data_used_gib)
  local reclaimed=$((before - after))
  printf '\n%sAfter:%s  %sG used on Data volume ' "$BLU" "$RST" "$after"
  if (( reclaimed > 0 )); then
    printf '(%s-%sG reclaimed%s)\n' "$GRN" "$reclaimed" "$RST"
  else
    printf '(no net change — Docker VM may need compacting via Docker Desktop → Troubleshoot → Clean/Purge data)\n'
  fi

  if (( ! CLEAN_NODE_MODULES || ! CLEAN_BUILD_ARTIFACTS || ! CLEAN_IOS_SIMULATORS || ! CLEAN_PLAYWRIGHT )); then
    printf '\n%sTip:%s re-run with %s--node-modules%s / %s--build-artifacts%s / %s--ios-simulators%s / %s--playwright%s / %s--all%s for more aggressive cleanup.\n' \
      "$DIM" "$RST" "$YLW" "$RST" "$YLW" "$RST" "$YLW" "$RST" "$YLW" "$RST" "$YLW" "$RST"
  fi
}

main "$@"
